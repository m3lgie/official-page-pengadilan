# ============================================================
#  .env.example — Salin ke .env dan sesuaikan sebelum jalankan
#  docker compose up -d --build
# ============================================================

# ─── IDENTITAS SATUAN KERJA (Diisi sesuai Pengadilan) ────────
SITE_URL=https://pn-namakota.go.id          # URL resmi website (tanpa trailing slash)

# ─── DATABASE ─────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_DB   # Wajib diubah! Gunakan 20+ karakter
DB_NAME=pengadilan_db

# ─── REDIS CACHE ──────────────────────────────────────────────
REDIS_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_REDIS

# ─── JWT SECRET (Backend Auth) ────────────────────────────────
JWT_SECRET=GANTI_DENGAN_SECRET_PANJANG_ADMIN_64CHAR
PUBLIC_JWT_SECRET=GANTI_DENGAN_SECRET_PANJANG_PUBLIK_64CHAR
# Tips: Gunakan perintah: openssl rand -hex 32

# ─── ENVIRONMENT ──────────────────────────────────────────────
APP_ENV=production
